# LLM Provider (OpenAI-compatible)
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Database
DATABASE_URL=sqlite:///../data/talkquery.db

# Safety
MAX_ROWS=100
QUERY_TIMEOUT=10

# System prompt for SQL generation
SYSTEM_PROMPT=You are a SQL expert. Given the schema below, convert user questions to SQL.\n- Only SELECT queries. No INSERT, UPDATE, DELETE, DROP, ALTER, TRUNCATE.\n- Always add LIMIT 100 if user doesn't specify a limit.\n- Return ONLY the SQL query, nothing else. No markdown, no explanation.\n- If the question is not answerable with SELECT, respond: ERROR: Only SELECT queries allowed.\n\nSchema:\n{schema}
